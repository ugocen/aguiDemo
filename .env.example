# Copy to .env and fill in real values. Never commit .env.

# ---------------------------------------------------------------------------
# Backend, general
# ---------------------------------------------------------------------------
APP_ENV=local
LOG_LEVEL=info
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Comma separated list of allowed origins for CORS.
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---------------------------------------------------------------------------
# Agent selection
# mock     deterministic scripted agent, no external calls, used for M1 and tests
# langgraph  real LangGraph agent calling the Marketplace client
# ---------------------------------------------------------------------------
AGENT_MODE=mock

# ---------------------------------------------------------------------------
# Model provider (vendor-agnostic). The LangGraph agent (AGENT_MODE=langgraph)
# streams through whichever provider is selected here; all expose the same
# interface, so the agent is unchanged across vendors.
#   marketplace  GenAI Marketplace gateway (OpenAI-compatible)
#   openai       OpenAI (or any OpenAI-compatible vendor)
#   anthropic    Anthropic (Claude)
#   gemini       Google Gemini
# ---------------------------------------------------------------------------
LLM_PROVIDER=marketplace
LLM_STREAM_MODE=stream
LLM_TIMEOUT_SECONDS=60

# marketplace
MARKETPLACE_BASE_URL=https://marketplace.example.com/v1
MARKETPLACE_API_KEY=replace-me
MARKETPLACE_MODEL=replace-me-model-id
MARKETPLACE_TENANT=
MARKETPLACE_STREAM_MODE=stream
MARKETPLACE_TIMEOUT_SECONDS=60

# openai
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# anthropic (Claude)
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
ANTHROPIC_VERSION=2023-06-01
ANTHROPIC_MAX_TOKENS=1024

# gemini
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ---------------------------------------------------------------------------
# Database. SQLite by default for local dev — no docker/Postgres needed. For
# Postgres via docker-compose: postgresql+asyncpg://agui:agui@localhost:5433/agui
# In the cloud, point this at RDS or a SQLite file on a persistent volume.
# ---------------------------------------------------------------------------
DATABASE_URL=sqlite+aiosqlite:///./agui.db

# ---------------------------------------------------------------------------
# Auth
# dev    trust a stub identity, no real sign-in (Phase 1 early)
# entra  validate Microsoft Entra bearer tokens (M-auth onward)
# ---------------------------------------------------------------------------
AUTH_MODE=dev
DEV_USER_ID=dev-user
DEV_USER_EMAIL=dev@example.com

# Entra / Azure AD validation, used when AUTH_MODE=entra. Client + tenant ids are
# public (they ship in the SPA); no client secret is used (PKCE). Example values
# are the demo "agui-test" app registration.
ENTRA_TENANT_ID=98c18fba-5be5-4229-a075-90da42d85df3
ENTRA_CLIENT_ID=1528c934-6675-4e0d-a674-b78cc9dd0538
ENTRA_AUDIENCE=
ENTRA_ISSUER=https://login.microsoftonline.com/98c18fba-5be5-4229-a075-90da42d85df3/v2.0

# ---------------------------------------------------------------------------
# Frontend (Next.js reads NEXT_PUBLIC_* at build time)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_AUTH_MODE=dev

# AG-UI client surface
# custom      hand-built client and cards, plus the event inspector (default)
# copilotkit  CopilotKit provider, CopilotChat, and useCopilotAction cards
NEXT_PUBLIC_CLIENT=custom

# Server-side URL the CopilotKit runtime route uses to reach the backend.
BACKEND_URL=http://localhost:8000
COPILOTKIT_TELEMETRY_DISABLED=true

# MSAL, used when NEXT_PUBLIC_AUTH_MODE=entra. Register each serving origin as a
# SPA redirect URI in the app registration (e.g. http://localhost:3000 and the
# production domain). Flip NEXT_PUBLIC_AUTH_MODE and AUTH_MODE to entra to enable.
NEXT_PUBLIC_ENTRA_CLIENT_ID=1528c934-6675-4e0d-a674-b78cc9dd0538
NEXT_PUBLIC_ENTRA_TENANT_ID=98c18fba-5be5-4229-a075-90da42d85df3
NEXT_PUBLIC_ENTRA_REDIRECT_URI=http://localhost:3000
NEXT_PUBLIC_ENTRA_SCOPE=
